{
  "compilerOptions": {
    "target": "es2020",
    "module": "nodenext",
    "lib": ["ES2020"],
    "rootDir": "./src",
    "outDir": "./build",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true,
    "removeComments": true,
    "paths": {
      "@prisma-client": ["./prisma/generated/prisma-client"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
