// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

generator zod {
  provider = "zod-prisma-types"
  output   = "../src/schemas/prisma-zod"
  addIncludeType = false
  addSelectType = false
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int       @id @default(autoincrement())
  username  String    @unique
  name      String    
  password  String
  wins      Int       @default(0)
  createdAt DateTime  @default(now())
  ownedRoom Room?     @relation("RoomOwner")
  joinedRoom  Room?   @relation("RoomPlayers", fields: [roomId], references: [id])
  roomId  Int?        
}

enum RoomStatus {
  LOBBY
  IN_GAME
}

model Room {
  id      Int         @id @default(autoincrement())
  code    String      @unique
  status  RoomStatus  @default(LOBBY)
  owner   User        @relation("RoomOwner", fields: [ownerId], references: [id])
  ownerId Int         @unique
  players User[]      @relation("RoomPlayers")
}
